---
import SiteLayout from './SiteLayout.astro';
import DeclarationCard from '../components/DeclarationCard.astro';
import PageRail from '../components/PageRail.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface TocHeading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	title: string;
	excerpt: string;
	publishDate: Date;
	updatedAt: Date;
	readingTime: string;
	wordCount: number;
	license: string;
	tags: string[];
	headings: TocHeading[];
	heroImage?: string;
}

const {
	title,
	excerpt,
	publishDate,
	updatedAt,
	readingTime,
	wordCount,
	license,
	tags,
	headings,
	heroImage = '/trueearth-hills.jpg',
} = Astro.props;

const publishedLabel = publishDate.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
const updatedLabel = updatedAt.toLocaleDateString('zh-CN', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
---

<SiteLayout title={`${title} | Evigila`} description={excerpt}>
	<main class="post-shell">
		<div class="post-layout">
			<PageRail commentsHref="#post-comments" />

			<div class="post-main">
				<article class="post-article" data-post-article>
					<header class="post-hero">
						<div class="post-hero__media" aria-hidden="true">
							<img src={heroImage} alt="" width="1280" height="720" loading="eager" />
						</div>
						<div class="post-hero__content">
							<p class="post-kicker">Static Journal</p>
							<h1>{title}</h1>
							<p class="post-excerpt">{excerpt}</p>
							<div class="post-meta">
								<span>发布于 {publishedLabel}</span>
								<span>·</span>
								<span>更新于 {updatedLabel}</span>
								<span>·</span>
								<span>{readingTime}</span>
								<span>·</span>
								<span>{wordCount.toLocaleString('zh-CN')} 词</span>
							</div>
							<div class="post-tags">
								{tags.map((tag) => <span>{tag}</span>)}
							</div>
						</div>
					</header>
					<div class="post-content" data-post-content>
						<slot />
					</div>
					<DeclarationCard publishDate={publishDate} license={license} />
				</article>

				<section class="post-panel post-comments" id="post-comments" aria-label="Comments">
					<p class="post-panel__kicker">Comments</p>
					<p class="post-panel__title">评论区</p>
					<div class="post-comments__widget">
						<script
							is:inline
							src="https://giscus.app/client.js"
							data-repo="Evigila/Blog"
							data-repo-id="R_kgDOSTv6rQ"
							data-category="Announcements"
							data-category-id="DIC_kwDOSTv6rc4C8n35"
							data-mapping="pathname"
							data-strict="0"
							data-reactions-enabled="1"
							data-emit-metadata="0"
							data-input-position="bottom"
							data-theme="preferred_color_scheme"
							data-lang="zh-CN"
							crossorigin="anonymous"
							async
						></script>
					</div>
				</section>
			</div>

			<aside class="post-sidebar" aria-label="Table of contents and reading progress">
				<div class="post-panel post-outline" data-post-outline style="--reading-progress: 0%;">
					<div class="post-outline__top">
						<div>
							<p class="post-panel__kicker">Contents</p>
							<p class="post-panel__title">文章大纲</p>
						</div>
						<p class="post-outline__progress" data-reading-progress-value>0%</p>
					</div>
					<div class="post-outline__bar" aria-hidden="true">
						<span></span>
					</div>

					{headings.length > 0 ? (
						<ol class="post-outline__list">
							{headings.map((heading) => (
								<li
									class={`post-outline__item post-outline__item--depth-${Math.min(Math.max(heading.depth, 2), 6)}`}
								>
									<a
										class="post-outline__link"
										href={`#${heading.slug}`}
										data-toc-link
										data-target-id={heading.slug}
									>
										<span>{heading.text}</span>
									</a>
								</li>
							))}
						</ol>
					) : (
						<p class="post-outline__empty">This post has no synchronized section headings.</p>
					)}
				</div>
			</aside>
		</div>

		<nav class="post-dock" aria-label="Post actions">
			<button class="post-dock__button post-dock__secondary action-button ui-button" type="button" data-scroll-top>
				返回顶端
			</button>
			<a class="post-dock__button post-dock__home action-button ui-button" href="/">返回主页</a>
			<a class="post-dock__button post-dock__secondary action-button ui-button" href="#post-comments">
				评论区
			</a>
		</nav>
	</main>

	<SiteFooter ariaLabel="Post footer" />

	<script>
		import { initPostPage } from '../scripts/post';

		initPostPage();
	</script>
</SiteLayout>
