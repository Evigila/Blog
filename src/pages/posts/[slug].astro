---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import { getPostSlug, calcReadingTime, calcWordCount, getUpdatedAt } from '../../data/blog';
import PostLayout from '../../layouts/PostLayout.astro';

interface Props {
	post: CollectionEntry<'blog'>;
}

export async function getStaticPaths() {
	const posts = await getCollection('blog');

	return posts.map((post) => ({
		params: { slug: getPostSlug(post) },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const publishDate = post.data.publishDate;
const updatedAt = getUpdatedAt(post);
const wordCount = calcWordCount(post.body ?? '');
const readingTime = calcReadingTime(wordCount);
---

<PostLayout
	title={post.data.title}
	excerpt={post.data.excerpt}
	publishDate={publishDate}
	updatedAt={updatedAt}
	readingTime={readingTime}
	wordCount={wordCount}
	license={post.data.license}
	tags={post.data.tags}
	headings={headings}
>
	<Content />
</PostLayout>