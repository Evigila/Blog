---
import PageRail from '../components/PageRail.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteLayout from '../layouts/SiteLayout.astro';

const friendLinks = [
	{
		name: 'Northlight Notes',
		href: 'https://example.com/northlight',
		description: 'Example site.',
	},
	{
		name: 'Quiet Build',
		href: 'https://example.com/quiet-build',
		description: 'Example site.',
	},
	{
		name: 'Archive Field',
		href: 'https://example.com/archive-field',
		description: 'Example site.',
	},
];
---

<SiteLayout title="Links | Evigila" description="Evigila's links page.">
	<main class="post-shell">
		<div class="post-layout post-layout--no-sidebar">
			<PageRail />

			<div class="post-main">
				<article class="post-article" data-post-article>
					<header class="post-hero post-hero--plain">
						<div class="post-hero__content">
							<p class="post-kicker ui-kicker">Friends</p>
							<h1>Links</h1>
							<p class="post-excerpt">A small placeholder set for friendly links.</p>
						</div>
					</header>
					<div class="post-content" data-post-content>
						<ul class="friend-link-list">
							{friendLinks.map((link) => (
								<li class="friend-link-list__item">
									<strong><a href={link.href}>{link.name}</a></strong>
									<p>{link.description}</p>
								</li>
							))}
						</ul>
					</div>
				</article>
			</div>

			<div class="post-sidebar-spacer" aria-hidden="true"></div>
		</div>

		<nav class="post-dock" aria-label="Page actions">
			<button class="post-dock__button post-dock__secondary action-button ui-button" type="button" data-scroll-top>
				Top
			</button>
			<a class="post-dock__button post-dock__home action-button ui-button" href="/">Home</a>
		</nav>
	</main>

	<SiteFooter ariaLabel="Links footer" />

	<script>
		import { initPostPage } from '../scripts/post';

		initPostPage();
	</script>
</SiteLayout>
