---
import { getCollection } from 'astro:content';
import { getPostSlug, sortPostsByUpdatedAt } from '../data/blog';
import { ICONS } from '../data/icons';
import { siteConfig } from '../data/site';
import SiteLayout from '../layouts/SiteLayout.astro';

const allPosts = sortPostsByUpdatedAt(await getCollection('blog'));
const posts = allPosts.map((post) => ({
	title: post.data.title,
	excerpt: post.data.excerpt,
	href: `/posts/${getPostSlug(post)}`,
	updatedAtLabel: (post.data.updatedAt ?? post.data.publishDate).toLocaleDateString('zh-CN', {
		year: 'numeric',
		month: '2-digit',
		day: '2-digit',
	}),
	tags: post.data.tags,
}));
const postCount = allPosts.length;
const latestPosts = posts.slice(0, 4);
const githubLink = siteConfig.socials.find((item) => item.icon === 'github')?.href ?? '#';
const mailLink = siteConfig.socials.find((item) => item.icon === 'mail')?.href ?? 'mailto:evigila.shangyi@gmail.com';
const tagFilters = Array.from(new Set(posts.flatMap((post) => post.tags))).filter(Boolean);
const interestTags = ['.NET', 'C#', 'Desktop', 'Windows', 'Godot'];
---

<SiteLayout title={siteConfig.title} description={siteConfig.description}>
	<main class="story-home is-cover" data-carousel-root data-view="cover">
	<section class="story-home__cover" aria-labelledby="cover-title">
		<div class="story-home__cover-left">
			<nav class="story-home__cover-nav" aria-label="Cover navigation">
				<button class="story-home__cover-nav-item" type="button" data-story-view="cover">Home</button>
				<button class="story-home__cover-nav-item" type="button" data-story-view="about">About</button>
				<button class="story-home__cover-nav-item" type="button" data-story-view="posts">Blogs</button>
				<a class="story-home__cover-nav-item" href={githubLink} target="_blank" rel="noreferrer">Github</a>
				<a class="story-home__cover-nav-item" href="/friend">Links</a>
			</nav>

			<div class="story-home__cover-stage">
				<div class="story-home__cover-copy story-home__cover-copy--home is-current" data-intro-panel="cover">
					<p class="story-home__eyebrow">Astro Static Journal</p>
					<div class="story-home__cover-title-lockup">
						<img src={siteConfig.author.avatar} alt="" width="112" height="112" />
						<h1 id="cover-title">Evigila</h1>
					</div>
					<p>
						Ne reculer devant aucun sacrifice, surmonter toutes les difficultés, remporter la victoire.
					</p>
				</div>

				<div class="story-home__cover-copy story-home__cover-copy--about" data-intro-panel="about" hidden>
					<p class="story-home__eyebrow">About Me</p>
					<h2>Evigila</h2>
					<p>{siteConfig.author.bio}</p>
					<div class="story-home__interest-tags" aria-label="Interests">
						{interestTags.map((tag) => (
							<span>{tag}</span>
						))}
					</div>
					<a class="story-home__contact-me" href={mailLink}>Contact me</a>
				</div>
			</div>

			<div class="story-home__cover-bottom">
				<button class="story-home__cover-down" type="button" data-cover-next aria-label="Show posts">
					<svg viewBox="0 0 48 48" aria-hidden="true">
						<path d="M12 19l12 12 12-12"></path>
					</svg>
				</button>
				<div class="story-home__utility-actions" aria-label="Page actions" role="group">
					<button class="story-home__utility-button theme-toggle" type="button" data-theme-toggle aria-pressed="false">
						<svg class="post-action-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.theme} fill="currentColor" />
						</svg>
						<span class="sr-only">Theme <strong data-theme-label>Light</strong></span>
					</button>
					<button class="story-home__utility-button" type="button" data-share aria-label="Share current page">
						<svg class="post-action-icon post-action-icon--share" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.share} fill="currentColor" />
						</svg>
						<svg class="post-action-icon post-action-icon--success" viewBox="0 0 24 24" aria-hidden="true">
							<path d={ICONS.check} fill="currentColor" />
						</svg>
					</button>
				</div>
			</div>
		</div>

		<aside class="story-home__cover-panel" aria-label="Latest posts">
			<div class="story-home__cover-panel-header">
				<p>Recently Updated</p>
				<button type="button" data-story-view="posts">see all {postCount} posts</button>
			</div>

			<div class="story-home__cover-posts">
				{latestPosts.map((post, index) => (
					<a class="story-home__cover-post" href={post.href}>
						<div class={`story-home__cover-post-media ${index === 0 ? 'has-image' : 'is-placeholder'}`} aria-hidden="true">
							{index === 0 ? (
								<img src="/trueearth-hills.jpg" alt="" loading="eager" />
							) : (
								<div class="story-home__media-placeholder">
									<span></span>
									<span></span>
									<span></span>
								</div>
							)}
						</div>
						<div class="story-home__cover-post-copy">
							<span>{post.updatedAtLabel}</span>
							<strong>{post.title}</strong>
							<em>{post.tags[0] ?? `Post ${index + 1}`}</em>
						</div>
					</a>
				))}
			</div>
		</aside>
	</section>

	<header class="story-home__header" aria-label="Primary navigation">
		<nav class="story-home__nav">
			<button class="story-home__nav-link" type="button" data-story-view="cover">Home</button>
			<button class="story-home__nav-link" type="button" data-story-view="about">About</button>
			<button class="story-home__nav-link" type="button" data-story-view="posts">Blogs</button>
			<a class="story-home__nav-link" href={githubLink} target="_blank" rel="noreferrer">Github</a>
			<a class="story-home__nav-link" href="/friend">Links</a>
		</nav>

		<a class="story-home__brand" href="/" aria-label={siteConfig.title}>
			<img src={siteConfig.author.avatar} alt="" width="24" height="24" />
			<span>{siteConfig.name}</span>
		</a>

		<div class="story-home__quick-actions">
			<button class="story-home__utility-button story-home__utility-button--header theme-toggle" type="button" data-theme-toggle aria-pressed="false">
				<svg class="post-action-icon" viewBox="0 0 24 24" aria-hidden="true">
					<path d={ICONS.theme} fill="currentColor" />
				</svg>
				<span class="sr-only">Theme <strong data-theme-label>Light</strong></span>
			</button>
			<button class="story-home__utility-button story-home__utility-button--header" type="button" data-share aria-label="Share current page">
				<svg class="post-action-icon post-action-icon--share" viewBox="0 0 24 24" aria-hidden="true">
					<path d={ICONS.share} fill="currentColor" />
				</svg>
				<svg class="post-action-icon post-action-icon--success" viewBox="0 0 24 24" aria-hidden="true">
					<path d={ICONS.check} fill="currentColor" />
				</svg>
			</button>
			<a class="story-home__icon-link" href={githubLink} target="_blank" rel="noreferrer" aria-label="Github">
				↗
			</a>
		</div>
	</header>

	<section class="story-home__title-row" aria-labelledby="home-title">
		<p class="story-home__eyebrow">Static Journal</p>
		<h1 id="home-title">
			What I Write
			<span aria-hidden="true">↳</span>
		</h1>
	</section>

	<section id="posts" class="story-home__content-row" aria-label="Blog posts">
		<aside class="story-home__filter-panel" aria-label="Filter posts by tag">
			<p>Filter · {postCount} posts</p>
			<div class="story-home__tag-list" data-filter-list tabindex="0">
				<button class="story-home__tag-button is-active" type="button" data-filter-tag="all">All</button>
				{tagFilters.map((tag) => (
					<button class="story-home__tag-button" type="button" data-filter-tag={tag}>{tag}</button>
				))}
			</div>
		</aside>

		<section class="story-home__carousel" aria-label="Blog posts carousel">
			<div class="story-home__orbit" aria-hidden="true"></div>

			<div class="story-home__track" data-carousel-track tabindex="0">
				{posts.map((post, index) => (
					<a
						class={`story-home__card ${index === 0 ? 'story-home__card--feature' : ''}`}
						href={post.href}
						data-card-index={index}
						data-post-tags={post.tags.join('|')}
					>
						<div class={`story-home__card-media ${index === 0 ? 'has-image' : 'is-placeholder'}`}>
							{index === 0 ? (
								<img src="/trueearth-hills.jpg" alt="" loading="eager" />
							) : (
								<div class="story-home__media-placeholder" aria-hidden="true">
									<span></span>
									<span></span>
									<span></span>
								</div>
							)}
						</div>

						<div class="story-home__card-kicker">
							<span>{post.updatedAtLabel}</span>
							<em>{String(index + 1).padStart(2, '0')}</em>
						</div>

						<h2>{post.title}</h2>
						<i aria-hidden="true"></i>
						<p>{post.excerpt}</p>

						<div class="story-home__card-footer">
							<span>{post.tags[0] ?? 'Blog'}</span>
							<strong>Read ↗</strong>
						</div>
					</a>
				))}
			</div>
		</section>
	</section>

	<footer class="story-home__footer-row">
		<div class="story-home__carousel-controls">
			<div class="story-home__arrows" aria-label="Carousel controls">
				<button type="button" data-carousel-start aria-label="Return to first post" hidden>
					<svg class="story-home__arrow-icon story-home__arrow-icon--double" viewBox="0 0 32 32" aria-hidden="true">
						<path d="M14 8 6 16l8 8"></path>
						<path d="M25 8l-8 8 8 8"></path>
					</svg>
				</button>
				<button type="button" data-carousel-prev aria-label="Previous post">
					<svg class="story-home__arrow-icon" viewBox="0 0 32 32" aria-hidden="true">
						<path d="M20 8l-8 8 8 8"></path>
					</svg>
				</button>
				<button type="button" data-carousel-next aria-label="Next post">
					<svg class="story-home__arrow-icon" viewBox="0 0 32 32" aria-hidden="true">
						<path d="M12 8l8 8-8 8"></path>
					</svg>
				</button>
			</div>
			<div class="story-home__progress" aria-hidden="true">
				<span></span>
			</div>
		</div>
	</footer>
	</main>
</SiteLayout>

<script>
	import { initHomeStory } from '../scripts/home-story';

	initHomeStory();
</script>

<style is:global>
	html.story-home-lock,
	body.story-home-lock,
	html:has(.story-home),
	body:has(.story-home) {
		overflow: hidden;
	}

	.story-home {
		--carousel-progress: 0;
		--page-margin: clamp(2rem, 3.2vw, 3.5rem);
		--column-gap: clamp(2rem, 3vw, 3.5rem);
		--row-gap: clamp(1.35rem, 2.7vh, 2.1rem);
		--left-column: clamp(14rem, 17vw, 16.5rem);
		--header-row: 3.6rem;
		--title-row: clamp(7rem, 15vh, 9rem);
		--footer-row: clamp(4.4rem, 8vh, 5.4rem);
		--card-gap: 1rem;
		--card-width: clamp(17.75rem, calc((100vw - 30rem) / 5.5), 22rem);
		--card-max-height: 31rem;
		position: relative;
		isolation: isolate;
		display: grid;
		grid-template-rows: var(--header-row) var(--title-row) minmax(0, 1fr) var(--footer-row);
		grid-template-columns: var(--left-column) minmax(0, 1fr);
		gap: var(--row-gap) var(--column-gap);
		height: 100svh;
		min-height: 44rem;
		padding: var(--page-margin);
		background:
			linear-gradient(90deg, color-mix(in srgb, var(--accent-0) 7%, transparent), transparent 26rem),
			linear-gradient(180deg, rgba(255, 255, 255, 0.68), transparent 18rem),
			var(--page-bg);
		color: var(--text-0);
		overflow: hidden;
	}

	.story-home::before {
		content: '';
		position: absolute;
		top: calc(var(--page-margin) + var(--header-row) + var(--title-row) * 0.48);
		right: calc(var(--page-margin) + 2rem);
		z-index: -2;
		width: min(32vw, 34rem);
		aspect-ratio: 1;
		border-radius: 50%;
		background: repeating-conic-gradient(
			from -18deg,
			color-mix(in srgb, var(--accent-0) 10%, transparent) 0deg 1.5deg,
			transparent 1.5deg 4.5deg
		);
		opacity: 0.22;
	}

	.story-home::after {
		content: '';
		position: absolute;
		inset: 0;
		z-index: -3;
		background-image:
			linear-gradient(to right, color-mix(in srgb, var(--border-0) 48%, transparent) 1px, transparent 1px),
			linear-gradient(to bottom, color-mix(in srgb, var(--border-0) 48%, transparent) 1px, transparent 1px);
		background-size: 5.5rem 5.5rem;
		mask-image: linear-gradient(180deg, #000, transparent 76%);
		opacity: 0.42;
	}

	.story-home__cover {
		position: absolute;
		inset: var(--page-margin);
		z-index: 5;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(24rem, 34vw);
		gap: var(--column-gap);
		min-height: 0;
		transition:
			opacity 360ms ease,
			transform 360ms ease,
			visibility 360ms ease;
	}

	.story-home[data-view='posts'] .story-home__cover,
	.story-home.is-posts .story-home__cover {
		visibility: hidden;
		opacity: 0;
		pointer-events: none;
		transform: translateY(-1.4rem) scale(0.985);
	}

	.story-home__cover-left {
		display: grid;
		grid-template-rows: var(--header-row) minmax(0, 1fr) var(--footer-row);
		min-height: 0;
	}

	.story-home__cover-nav {
		display: inline-flex;
		align-items: center;
		gap: 0;
		justify-self: center;
		padding: 0.28rem;
		border: 1px solid color-mix(in srgb, var(--border-0) 76%, transparent);
		border-radius: 6px;
		background: color-mix(in srgb, var(--surface-1) 78%, transparent);
		box-shadow: 0.45rem 0.45rem 0 color-mix(in srgb, var(--accent-0) 9%, transparent);
	}

	.story-home__cover-nav-item {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		height: 3rem;
		padding: 0 1.25rem;
		border: 0;
		border-radius: 4px;
		background: transparent;
		color: var(--text-1);
		font-size: 0.98rem;
		font-weight: 900;
		transition:
			background 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.story-home__cover-nav-item:hover,
	.story-home__cover-nav-item:focus-visible {
		color: var(--accent-0);
		transform: translateY(-0.06rem);
	}

	.story-home[data-view='cover'] .story-home__cover-nav-item[data-story-view='cover'],
	.story-home[data-view='about'] .story-home__cover-nav-item[data-story-view='about'],
	.story-home[data-view='posts'] .story-home__cover-nav-item[data-story-view='posts'],
	.story-home.is-cover .story-home__cover-nav-item[data-story-view='cover'],
	.story-home.is-about .story-home__cover-nav-item[data-story-view='about'],
	.story-home.is-posts .story-home__cover-nav-item[data-story-view='posts'],
	.story-home__cover-nav-item.is-active {
		background: var(--accent-0);
		color: #fff;
	}

	.story-home__cover-stage {
		position: relative;
		align-self: center;
		min-height: clamp(20rem, 42vh, 27rem);
		max-width: min(48rem, 72vw);
		padding-bottom: clamp(1rem, 5vh, 4rem);
	}

	.story-home__cover-copy {
		position: absolute;
		inset: 0;
		display: flex;
		flex-direction: column;
		justify-content: center;
		visibility: hidden;
		opacity: 0;
		pointer-events: none;
		transform: translateY(1.25rem);
	}

	.story-home__cover-copy.is-current {
		visibility: visible;
		opacity: 1;
		pointer-events: auto;
		animation: story-intro-panel-in 360ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
	}

	.story-home__cover-copy.is-exiting {
		visibility: visible;
		pointer-events: none;
		animation: story-intro-panel-out 260ms ease both;
	}

	.story-home__cover-title-lockup {
		display: flex;
		align-items: center;
		gap: clamp(1.05rem, 2vw, 1.7rem);
	}

	.story-home__cover-title-lockup img {
		width: clamp(4.2rem, 7.2vw, 7rem);
		height: clamp(4.2rem, 7.2vw, 7rem);
		border: 1px solid color-mix(in srgb, var(--accent-0) 40%, var(--border-0));
		border-radius: 6px;
		box-shadow: 0.55rem 0.55rem 0 color-mix(in srgb, var(--accent-0) 12%, transparent);
		object-fit: cover;
	}

	.story-home .story-home__cover-copy h1 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(5rem, 9vw, 9.2rem);
		line-height: 0.9;
		letter-spacing: -0.05em;
	}

	.story-home__cover-copy p:last-child {
		max-width: 37rem;
		margin: 1.6rem 0 0;
		color: var(--text-1);
		font-size: clamp(1rem, 1.35vw, 1.3rem);
		font-weight: 700;
		line-height: 1.48;
	}

	.story-home__cover-copy--about {
		max-width: 39rem;
	}

	.story-home__cover-copy--about h2 {
		margin: 0;
		font-family: var(--font-display);
		font-size: clamp(2.4rem, 4.6vw, 4.1rem);
		line-height: 0.95;
		letter-spacing: -0.035em;
	}

	.story-home__cover-copy--about p:not(.story-home__eyebrow) {
		max-width: 35rem;
		margin: 1.25rem 0 0;
		color: var(--text-1);
		font-size: clamp(1rem, 1.2vw, 1.2rem);
		font-weight: 700;
		line-height: 1.52;
	}

	.story-home__interest-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.72rem;
		max-width: 34rem;
		margin-top: 1.55rem;
	}

	.story-home__interest-tags span,
	.story-home__contact-me {
		border: 1px solid color-mix(in srgb, var(--border-0) 72%, transparent);
		border-radius: 6px;
		background: color-mix(in srgb, var(--surface-1) 76%, transparent);
		box-shadow: 0.28rem 0.28rem 0 color-mix(in srgb, var(--accent-0) 8%, transparent);
		font-weight: 900;
	}

	.story-home__interest-tags span {
		padding: 0.72rem 1rem;
		color: var(--text-1);
		font-size: 1rem;
	}

	.story-home__interest-tags span:nth-child(1) {
		background: color-mix(in srgb, #dff3ff 78%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(37, 99, 235, 0.13);
		color: #1554a8;
	}

	.story-home__interest-tags span:nth-child(2) {
		background: color-mix(in srgb, #efe4ff 78%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(124, 58, 237, 0.12);
		color: #6541a8;
	}

	.story-home__interest-tags span:nth-child(3) {
		background: color-mix(in srgb, #e4f8ec 80%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(22, 163, 74, 0.12);
		color: #1d7141;
	}

	.story-home__interest-tags span:nth-child(4) {
		background: color-mix(in srgb, #fff1d8 80%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(217, 119, 6, 0.12);
		color: #9a5b12;
	}

	.story-home__interest-tags span:nth-child(5) {
		background: color-mix(in srgb, #ffe4ec 78%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(219, 39, 119, 0.11);
		color: #9c315e;
	}

	.story-home__interest-tags span:nth-child(6) {
		background: color-mix(in srgb, #e2f1f0 78%, var(--surface-1));
		box-shadow: 0.3rem 0.3rem 0 rgba(13, 148, 136, 0.11);
		color: #206d68;
	}

	.story-home__contact-me {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: fit-content;
		height: 3rem;
		margin-top: 1.45rem;
		padding: 0 1.15rem;
		color: var(--accent-0);
		transition:
			transform 180ms ease,
			box-shadow 180ms ease,
			border-color 180ms ease;
	}

	.story-home__contact-me:hover,
	.story-home__contact-me:focus-visible {
		border-color: color-mix(in srgb, var(--accent-0) 42%, var(--border-0));
		box-shadow: 0.42rem 0.42rem 0 color-mix(in srgb, var(--accent-0) 13%, transparent);
		transform: translate(-0.1rem, -0.1rem);
	}

	.story-home__cover-bottom {
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 1rem;
		align-self: end;
	}

	.story-home__cover-down {
		display: grid;
		place-items: center;
		justify-self: start;
		align-self: end;
		width: 7rem;
		height: 7rem;
		border: 0;
		background: transparent;
		box-shadow: none;
		color: #1a1a1a;
		animation: story-cover-arrow-float 1.55s ease-in-out infinite;
		transition:
			color 180ms ease,
			transform 180ms ease;
	}

	.story-home__cover-down:hover,
	.story-home__cover-down:focus-visible {
		color: #1a1a1a;
	}

	.story-home__cover-down svg {
		width: 6.6rem;
		height: 6.6rem;
	}

	.story-home__cover-down path {
		fill: none;
		stroke: currentColor;
		stroke-width: 3;
		stroke-linecap: round;
		stroke-linejoin: round;
	}

	.story-home__cover-panel {
		position: relative;
		display: grid;
		grid-template-rows: auto minmax(0, 1fr);
		align-self: stretch;
		min-height: 0;
